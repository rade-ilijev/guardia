<?xml version="1.0" encoding="utf-8"?>
<!--
    Play-flavor manifest overlay. Strips the most heavily-scrutinized Play capabilities from the
    merged manifest so the store build only carries camera-FGS, device admin, overlay and
    (minimal) accessibility. SMS find-my-phone and background location are full-flavor only.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SEND_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" tools:node="remove" />

    <application>
        <!-- No SMS-triggered find-my-phone in the Play build. -->
        <receiver android:name=".core.alerts.SmsReceiver" tools:node="remove" />
    </application>
</manifest>
